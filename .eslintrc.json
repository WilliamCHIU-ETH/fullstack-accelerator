{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-console": "off",
    "quotes": ["error", "single", { "avoidEscape": true }],
    "indent": ["error", 2],
    "camelcase": ["warn", { "properties": "never" }]
  },
  "ignorePatterns": ["node_modules/", "dist/", ".ref/"]
}
